{
  "name": "sokoban-like-prototype-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "inspect": "tsx src/cli.ts inspect prototypes/pull_portal_fallback",
    "solve": "tsx src/cli.ts solve prototypes/pull_portal_fallback",
    "explain:level": "tsx src/cli.ts explain-level prototypes/pull_portal_fallback",
    "explain:layout": "tsx src/cli.ts explain-layout prototypes/pull_portal_fallback",
    "evaluate": "tsx src/cli.ts evaluate prototypes/pull_portal_fallback",
    "evaluate:write": "tsx src/cli.ts evaluate prototypes/pull_portal_fallback --write",
    "coverage": "tsx src/cli.ts coverage prototypes/pull_portal_fallback",
    "audit": "tsx src/cli.ts audit prototypes/pull_portal_fallback",
    "audit:write": "tsx src/cli.ts audit prototypes/pull_portal_fallback --write",
    "curriculum:v2": "tsx src/cli.ts curriculum-v2 prototypes/pull_portal_fallback",
    "curriculum:v2:write": "tsx src/cli.ts curriculum-v2 prototypes/pull_portal_fallback --write",
    "level-specs:v2": "tsx src/cli.ts level-specs-v2 prototypes/pull_portal_fallback",
    "level-specs:v2:write": "tsx src/cli.ts level-specs-v2 prototypes/pull_portal_fallback --write",
    "mine": "tsx src/cli.ts mine prototypes/pull_portal_fallback",
    "mine:write": "tsx src/cli.ts mine prototypes/pull_portal_fallback --write",
    "generate:v2": "tsx src/cli.ts generate-v2 prototypes/pull_portal_fallback --write",
    "candidate-gallery:v2": "tsx src/cli.ts candidate-gallery-v2 prototypes/pull_portal_fallback --write",
    "evaluate:v2": "tsx src/cli.ts evaluate-v2 prototypes/pull_portal_fallback",
    "evaluate:v2:write": "tsx src/cli.ts evaluate-v2 prototypes/pull_portal_fallback --write",
    "calibration": "tsx src/cli.ts calibration-report prototypes/pull_portal_fallback",
    "calibration:write": "tsx src/cli.ts calibration-report prototypes/pull_portal_fallback --write",
    "playable:build": "tsx src/playable/exportPlayable.ts prototypes/pull_portal_fallback",
    "playable:serve": "python -m http.server 4173 -d prototypes/pull_portal_fallback/playable",
    "ps:export": "tsx src/exporters/exportPuzzleScriptNext.ts prototypes/pull_portal_fallback",
    "ps:check": "tsx src/exporters/checkPuzzleScriptNext.ts prototypes/pull_portal_fallback",
    "validate": "npm run check && npm run evaluate:write && npm run coverage && npm run playable:build && npm run ps:export && npm run ps:check && npm run audit:write"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
