{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sokoban/mechanic.schema.json",
  "title": "Mechanic",
  "type": "object",
  "required": ["id", "title", "version", "objects", "inputs", "rules", "win"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "objects": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/objectDef" }
    },
    "layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "inputs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/inputDef" }
    },
    "state": {
      "type": "object",
      "additionalProperties": true
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" },
      "minItems": 1
    },
    "win": { "$ref": "#/$defs/winCondition" },
    "counterfactuals": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/counterfactual" }
    },
    "optimizations": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/optimization" }
    },
    "export": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "objectDef": {
      "type": "object",
      "required": ["glyph", "layer"],
      "additionalProperties": false,
      "properties": {
        "glyph": { "type": "string", "minLength": 1 },
        "layer": { "$ref": "#/$defs/id" },
        "color": { "type": "string" },
        "traits": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "vars": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "array" },
              { "type": "object" }
            ]
          }
        },
        "export": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "inputDef": {
      "type": "object",
      "required": ["intent"],
      "additionalProperties": true,
      "properties": {
        "intent": { "$ref": "#/$defs/id" },
        "dir": {
          "type": "string",
          "enum": ["up", "down", "left", "right"]
        },
        "cost": { "type": "number", "minimum": 0 },
        "description": { "type": "string" }
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "trigger"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "priority": { "type": "integer" },
        "phase": { "$ref": "#/$defs/id" },
        "trigger": { "type": "object", "additionalProperties": true },
        "when": { "type": "object", "additionalProperties": true },
        "effect": { "type": "object", "additionalProperties": true },
        "branches": {
          "type": "array",
          "items": { "$ref": "#/$defs/branch" }
        },
        "emits": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "teaches": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "effects": { "$ref": "#/$defs/effectSummary" },
        "notes": { "type": "string" }
      },
      "oneOf": [
        { "required": ["effect"] },
        { "required": ["branches"] }
      ]
    },
    "branch": {
      "type": "object",
      "required": ["id", "when", "effect"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "when": { "type": "object", "additionalProperties": true },
        "effect": { "type": "object", "additionalProperties": true },
        "emits": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "teaches": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "effects": { "$ref": "#/$defs/effectSummary" },
        "notes": { "type": "string" }
      }
    },
    "effectSummary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reads": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "writes": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "emits": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "locality": {
          "type": "string",
          "enum": ["local", "global", "spatial_nonlocal", "unknown"]
        },
        "reversible": {
          "type": "string",
          "enum": ["true", "false", "conditional", "unknown"]
        },
        "notes": { "type": "string" }
      }
    },
    "winCondition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": { "$ref": "#/$defs/id" },
        "description": { "type": "string" }
      }
    },
    "counterfactual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "disable_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "disable_branches": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*\\.[A-Za-z][A-Za-z0-9_]*$" },
          "uniqueItems": true
        },
        "replace": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "optimization": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "unknown", "manual_override"]
        },
        "notes": { "type": "string" }
      }
    }
  }
}

