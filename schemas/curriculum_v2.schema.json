{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sokoban/curriculum_v2.schema.json",
  "title": "CurriculumV2",
  "type": "object",
  "required": ["mechanic", "status", "target_policy", "assumed_known", "units"],
  "additionalProperties": false,
  "properties": {
    "mechanic": { "$ref": "#/$defs/id" },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "active"]
    },
    "target_level_count": { "type": "integer", "minimum": 1 },
    "target_policy": {
      "type": "object",
      "required": ["formal_targets", "assumed_rules", "embedded_boundaries", "generator_guardrails"],
      "additionalProperties": false,
      "properties": {
        "formal_targets": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "minItems": 1,
          "uniqueItems": true
        },
        "assumed_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "embedded_boundaries": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "generator_guardrails": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "notes": { "type": "string" }
      }
    },
    "assumed_known": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "ordering_notes": { "type": "string" },
    "units": {
      "type": "array",
      "items": { "$ref": "#/$defs/unit" },
      "minItems": 1
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "targetKind": {
      "type": "string",
      "enum": ["fact", "constraint", "interaction", "ability", "pattern"]
    },
    "role": {
      "type": "string",
      "enum": [
        "diagnostic",
        "discovery",
        "boundary",
        "guided_application",
        "independent_application",
        "variation_transfer",
        "combination",
        "challenge",
        "review"
      ]
    },
    "supportLevel": {
      "type": "string",
      "enum": ["none", "low", "medium", "high"]
    },
    "solverEvidence": {
      "type": "string",
      "enum": [
        "solvable",
        "player_win_standard",
        "target_event_detector_configured",
        "expected_trace_replays",
        "returned_solution_covers_target_events",
        "expected_trace_covers_target_events",
        "all_shortest_solutions_cover_target_events",
        "all_winning_paths_cover_target_events",
        "counterfactual_unsolvable",
        "full_graph_complete"
      ]
    },
    "llmPlayerEvidence": {
      "type": "string",
      "enum": [
        "tries_old_model",
        "observes_old_model_failure",
        "forms_target_hypothesis",
        "revises_rule_model",
        "uses_target_hypothesis_to_finish",
        "applies_known_target_without_relearning",
        "forms_subgoal_chain",
        "identifies_bottleneck",
        "reports_goal_clear",
        "reports_rule_confusion",
        "recovers_from_failed_model"
      ]
    },
    "targetRef": {
      "type": "object",
      "required": ["kind", "ref"],
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/targetKind" },
        "ref": { "$ref": "#/$defs/id" }
      }
    },
    "softOrdering": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "locality": {
          "type": "string",
          "enum": ["local", "regional", "remote", "mixed", "unknown"]
        },
        "observability": {
          "type": "string",
          "enum": ["direct", "indirect", "structural", "unknown"]
        },
        "mechanism_count": { "type": "integer", "minimum": 1 },
        "state_space_burden": {
          "type": "string",
          "enum": ["low", "medium", "high", "unknown"]
        },
        "notes": { "type": "string" }
      }
    },
    "unit": {
      "type": "object",
      "required": ["id", "title", "goals"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "goals": {
          "type": "array",
          "items": { "$ref": "#/$defs/goal" },
          "minItems": 1
        }
      }
    },
    "goal": {
      "type": "object",
      "required": [
        "id",
        "target",
        "known_before",
        "hard_prerequisites",
        "role_sequence",
        "support_level",
        "blocked_by_open_questions",
        "ordering_rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "target": { "$ref": "#/$defs/targetRef" },
        "known_before": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "hard_prerequisites": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "role_sequence": {
          "type": "array",
          "items": { "$ref": "#/$defs/role" },
          "minItems": 1,
          "uniqueItems": true
        },
        "support_level": { "$ref": "#/$defs/supportLevel" },
        "soft_ordering": { "$ref": "#/$defs/softOrdering" },
        "bundle_with": {
          "type": "array",
          "items": { "$ref": "#/$defs/id" },
          "uniqueItems": true
        },
        "blocked_by_open_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "expected_solver_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/solverEvidence" },
          "uniqueItems": true
        },
        "expected_llm_player_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/llmPlayerEvidence" },
          "uniqueItems": true
        },
        "ordering_rationale": { "type": "string", "minLength": 1 },
        "notes": { "type": "string" }
      }
    }
  }
}
