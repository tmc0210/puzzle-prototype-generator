========
LEGEND
========

. = Background
# = Wall
G = Target
@ = Player
C = Crate
A = PortalA
B = PortalB
D = PortalD
E = PortalE
H = PortalH
I = PortalI

Portal = PortalA or PortalB or PortalD or PortalE or PortalH or PortalI
Marker = DirRight or DirLeft or DirUp or DirDown
Blocking = Wall or Crate or PortalA or PortalB or PortalD or PortalE or PortalH or PortalI

